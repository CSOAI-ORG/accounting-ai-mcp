{
  "name": "accounting-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 MEOK AI Labs MCP Server",
  "version": "1.0.0",
  "tools": [
    {
      "name": "generate_invoice",
      "description": "Generate a professional invoice with line items, VAT, and totals.",
      "parameters": {
        "type": "object",
        "properties": {
          "business_name": {
            "type": "string"
          },
          "client_name": {
            "type": "string"
          },
          "items": {
            "type": "array"
          },
          "currency": {
            "type": "string"
          },
          "country_code": {
            "type": "string"
          },
          "invoice_number": {
            "type": "string"
          },
          "due_days": {
            "type": "integer"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "business_name",
          "client_name",
          "items"
        ]
      }
    },
    {
      "name": "categorize_expenses",
      "description": "Automatically categorize business expenses by type.",
      "parameters": {
        "type": "object",
        "properties": {
          "expenses": {
            "type": "array"
          }
        },
        "required": [
          "expenses"
        ]
      }
    },
    {
      "name": "calculate_vat",
      "description": "Calculate VAT/tax for any country with support for inclusive/exclusive amounts.",
      "parameters": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "country_code": {
            "type": "string"
          },
          "vat_inclusive": {
            "type": "boolean"
          },
          "custom_rate": {
            "type": "number"
          }
        },
        "required": [
          "amount"
        ]
      }
    },
    {
      "name": "profit_and_loss",
      "description": "Generate a profit and loss statement from income and expense records.",
      "parameters": {
        "type": "object",
        "properties": {
          "income": {
            "type": "array"
          },
          "expenses": {
            "type": "array"
          },
          "period_start": {
            "type": "string"
          },
          "period_end": {
            "type": "string"
          }
        },
        "required": [
          "income",
          "expenses"
        ]
      }
    },
    {
      "name": "bank_reconciliation",
      "description": "Reconcile bank statement transactions against book records.",
      "parameters": {
        "type": "object",
        "properties": {
          "bank_transactions": {
            "type": "array"
          },
          "book_transactions": {
            "type": "array"
          },
          "tolerance": {
            "type": "number"
          }
        },
        "required": [
          "bank_transactions",
          "book_transactions"
        ]
      }
    }
  ]
}